{
  "name": "privacy-preserving-crdt-editor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A Yjs-based structured collaborative editor with privacy-preserving views.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "tsx src/server/main.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "ws": "^8.21.0",
    "yjs": "^13.6.27"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@types/ws": "^8.18.1",
    "tsx": "^4.22.3",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
